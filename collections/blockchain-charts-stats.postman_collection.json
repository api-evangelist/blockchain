    {
      "id": "cc9d685f-2bc0-434f-9e8d-016c83bb116f",
      "name": "Charts",
      "description": {
        "content": "Historical time-series datasets for Bitcoin network metrics.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "d40e5498-4388-43ae-b6ad-95b784245bd1",
          "name": "Blockchain.com Get a Chart Time-series",
          "request": {
            "name": "Blockchain.com Get a Chart Time-series",
            "description": {
              "content": "Returns a time-series dataset for the requested chart name. Common chart names include\n`transactions-per-second`, `market-price`, `hash-rate`, `difficulty`, `miners-revenue`,\n`mempool-size`, `n-transactions`, `total-bitcoins`, `avg-block-size`, `mempool-count`,\n`cost-per-transaction`, and many others.\n",
              "type": "text/plain"
            },
            "url": {
              "protocol": "https",
              "path": [
                "charts",
                ":chartName"
              ],
              "host": [
                "api",
                "blockchain",
                "info"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "timespan",
                  "value": "1year",
                  "description": "Duration spanned by the dataset (e.g. `5weeks`, `1year`, `all`). Default `1year`."
                },
                {
                  "disabled": false,
                  "key": "rollingAverage",
                  "value": "<string>",
                  "description": "Smoothing window applied to the time series (e.g. `8hours`, `7days`)."
                },
                {
                  "disabled": false,
                  "key": "start",
                  "value": "<date>",
                  "description": "Custom start date in `YYYY-MM-DD` format."
                },
                {
                  "disabled": false,
                  "key": "format",
                  "value": "json",
                  "description": "Response format (`json` or `csv`). Default `json`."
                },
                {
                  "disabled": false,
                  "key": "sampled",
                  "value": "false",
                  "description": "If true, downsample to ~1.5k points for performance."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "chartName",
                  "description": "(Required) Chart identifier (kebab-case)."
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
          "response": [
            {
