{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/blockchain/refs/heads/main/json-schema/com-exchange-heartbeat-update-payload-schema.json",
  "title": "ExchangeHeartbeatUpdatePayload",
  "description": "ExchangeHeartbeatUpdatePayload schema from Blockchain.com WebSocket APIs",
  "type": "object",
  "properties": {
    "seqnum": {
      "type": "integer"
    },
    "event": {
      "type": "string",
      "const": "updated"
    },
    "channel": {
      "type": "string",
      "const": "heartbeat"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "seqnum",
    "event",
    "channel",
    "timestamp"
  ]
}
