  "title": "ExchangeAuthRejectedPayload",
  "description": "ExchangeAuthRejectedPayload schema from Blockchain.com WebSocket APIs",
  "type": "object",
  "properties": {
    "seqnum": {
      "type": "integer"
    },
    "event": {
      "type": "string",
      "const": "rejected"
    },
    "channel": {
      "type": "string",
      "const": "auth"
    },
    "text": {
      "type": "string"
    }
  },
  "required": [
    "seqnum",
    "event",
    "channel",
    "text"
  ]
}
