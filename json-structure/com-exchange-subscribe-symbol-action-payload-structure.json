  "name": "ExchangeSubscribeSymbolActionPayload",
  "description": "ExchangeSubscribeSymbolActionPayload schema from Blockchain.com WebSocket APIs",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "subscribe",
        "unsubscribe"
