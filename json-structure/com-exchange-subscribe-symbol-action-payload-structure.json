      "enum": [
        "l2",
        "l3",
        "ticker",
        "trades"
      ]
    },
    "symbol": {
      "type": "string",
      "description": "Exchange symbol identifier, e.g. \"BTC-USD\"."
    }
  },
  "required": [
    "action",
    "channel",
    "symbol"
  ]
}
